<configuration>
    <!-- 1. Cấu hình in ra Console (Màn hình Terminal) -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!-- Định dạng: Thời gian | Mức độ | Tên Class | Nội dung -->
            <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level [%thread] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- 2. Cấu hình FileAppender để ghi log ra file vật lý -->
    <appender name="FILE" class="ch.qos.logback.core.FileAppender">
        <!-- Đường dẫn tạo file log -->
        <file>logs/application.log</file>
        <append>true</append>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level [%thread] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Áp dụng cho toàn bộ dự án ở mức độ INFO trở lên -->
    <root level="INFO">
        <appender-ref ref="STDOUT" />
        <appender-ref ref="FILE" />
    </root>
</configuration>